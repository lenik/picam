#: src/camview.c:32
msgid ""
"Usage: camview [OPTION]... [FILE]...\n"
"Concatenate FILE(s) to standard output. With no FILE, or when FILE is -,\n"
"read standard input.\n"
msgstr ""
"Cách dùng: camview [OPTION]... [FILE]...\n"
"Nối các FILE và ghi ra đầu ra chuẩn. Khi không có FILE hoặc FILE là -,\n"
"đọc từ đầu vào chuẩn.\n"

#: src/camview.c:38
msgid "repeat for more verbose loggings\n"
msgstr "lap lai de hien thi nhieu nhat ky chi tiet hon\n"

#: src/camview.c:40
msgid "show less logging messages\n"
msgstr "hien thi it thong diep nhat ky hon\n"

#: src/camview.c:42
msgid "display this help and exit\n"
msgstr "hiển thị trợ giúp này và thoát\n"

#: src/camview.c:44
msgid "output version information and exit\n"
msgstr "in thông tin phiên bản và thoát\n"

#: src/camview.c:46
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "Báo lỗi tới: <%s>\n"

#: src/camview.c:54
#, c-format
msgid "hello, world!\n"
msgstr "Xin chào, thế giới!\n"

