#: src/camview.c:42
msgid ""
"Usage: camview [OPTION]...\n"
"Raspberry Pi 5 CSI/MIPI camera preview and capture (GStreamer + libcamera).\n"
msgstr ""
"用法：camview [选项]...\n"
"树莓派 5 CSI/MIPI 摄像头预览与采集（GStreamer + libcamera）。\n"

#: src/camview.c:46
msgid "Preview (graphical):\n"
msgstr "预览（图形界面）：\n"

#: src/camview.c:49
msgid "Capture (headless):\n"
msgstr "采集（无界面/无头）：\n"

#: src/camview.c:56
msgid "Camera:\n"
msgstr "摄像头：\n"

#: src/camview.c:61
msgid "Image / video tuning:\n"
msgstr "图像 / 视频调节：\n"

#: src/camview.c:70
msgid "repeat for more verbose loggings\n"
msgstr "重复使用以输出更多详细日志\n"

#: src/camview.c:72
msgid "show less logging messages\n"
msgstr "显示更少的日志消息\n"

#: src/camview.c:74
msgid "display this help and exit\n"
msgstr "显示此帮助并退出\n"

#: src/camview.c:76
msgid "output version information and exit\n"
msgstr "输出版本信息并退出\n"

#: src/camview.c:78
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "报告问题到：<%s>\n"

#: src/camview.c:201
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "版权所有 (C) %d %s\n"

#: src/camview.c:202
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr ""
"许可证 AGPL-3.0-or-later：<https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/camview.c:204
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "这是自由软件：你可以自由修改并重新分发。\n"

#: src/camview.c:206
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "本项目反对 AI 剥削与 AI 霸权。\n"

#: src/camview.c:207
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr "本项目反对无脑 MIT 式许可证和政治愚蠢 BSD 式许可证。\n"

#: src/camview.c:210
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "在法律允许范围内，不提供任何担保。\n"

#: src/lib.c:49
#, c-format
msgid "%s: write error\n"
msgstr "%s: 写入错误\n"

